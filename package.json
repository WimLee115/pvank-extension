{
  "name": "pvank-extension",
  "version": "0.3.0",
  "description": "Verzegel deze pagina — browser-extensie voor PVANK (cryptografisch bewijs van wat je nu ziet)",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "author": "wimlee",
  "homepage": "https://github.com/WimLee115/pvank-extension",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WimLee115/pvank-extension.git"
  },
  "scripts": {
    "dev:chrome": "TARGET=chrome vite build --watch --mode development",
    "dev:firefox": "TARGET=firefox vite build --watch --mode development",
    "build": "npm run build:chrome && npm run build:firefox",
    "build:chrome": "TARGET=chrome vite build && node scripts/finalize.mjs chrome",
    "build:firefox": "TARGET=firefox vite build && node scripts/finalize.mjs firefox",
    "package": "npm run build && node scripts/package.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist dist-chrome dist-firefox coverage"
  },
  "dependencies": {
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.42",
    "@types/firefox-webext-browser": "^143.0.0",
    "@types/node": "^25.8.0",
    "@vitest/coverage-v8": "^4.1.6",
    "happy-dom": "^20.9.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.5"
  }
}
